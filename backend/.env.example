# Anthropic
ANTHROPIC_API_KEY=

# Server
HOST=127.0.0.1
PORT=8787
# Include app://bundle so a packaged Electron build (renderer origin app://bundle)
# passes CORS when talking to a tunneled backend.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,app://bundle

# Session
SESSION_TTL_SECONDS=1800
MAX_IMAGE_BYTES=2097152

# Model
ANTHROPIC_MODEL=claude-opus-4-7
