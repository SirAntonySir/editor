    { "param_key": "red",   "control_type": "curve_editor", "label": "Red",   "group": "Channels" },
    { "param_key": "green", "control_type": "curve_editor", "label": "Green", "group": "Channels" },
    { "param_key": "blue",  "control_type": "curve_editor", "label": "Blue",  "group": "Channels" }
