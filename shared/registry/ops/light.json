{
  "id": "light",
  "display_name": "Light",
  "icon": "light_mode",
  "category": "tone",
  "llm": {
    "description": "Tonal range controls — exposure, contrast, and per-zone tweaks (highlights, shadows, whites, blacks, brightness).",
    "typical_use": "Brightening a too-dark photo, recovering blown highlights, deepening shadows, base tone shaping.",
    "semantic_tags": ["tone", "exposure", "basic", "light", "brightness", "highlights", "shadows", "contrast", "dark", "bright", "recover", "lift"]
  },
  "params": {
    "exposure":   { "type": "scalar", "range": [-100, 100], "default": 0 },
    "brightness": { "type": "scalar", "range": [-100, 100], "default": 0 },
    "contrast":   { "type": "scalar", "range": [-100, 100], "default": 0 },
    "highlights": { "type": "scalar", "range": [-100, 100], "default": 0 },
    "shadows":    { "type": "scalar", "range": [-100, 100], "default": 0 },
    "whites":     { "type": "scalar", "range": [-100, 100], "default": 0 },
    "blacks":     { "type": "scalar", "range": [-100, 100], "default": 0 }
  },
  "bindings": [
    { "paramKey": "exposure",   "controlType": "slider", "label": "Exposure" },
    { "paramKey": "brightness", "controlType": "slider", "label": "Brightness" },
    { "paramKey": "contrast",   "controlType": "slider", "label": "Contrast" },
    { "paramKey": "highlights", "controlType": "slider", "label": "Highlights" },
    { "paramKey": "shadows",    "controlType": "slider", "label": "Shadows" },
    { "paramKey": "whites",     "controlType": "slider", "label": "Whites" },
    { "paramKey": "blacks",     "controlType": "slider", "label": "Blacks" }
  ],
  "engine": { "shader": "basic", "render_order": 10, "node_type": "basic" },
  "tool_defaults": ["exposure", "contrast", "highlights", "shadows"]
}
