{
  "id": "splitTone",
  "display_name": "Split Tone",
  "icon": "gradient",
  "category": "color",
  "llm": {
    "description": "Independently color-tones shadows and highlights with hue + saturation per zone and a balance slider.",
    "typical_use": "Cinematic teal-orange, warm shadows + cool highlights, vintage color cast.",
    "semantic_tags": ["color-grade", "mood", "vintage", "cinematic", "teal-orange", "split-tone", "warm-shadows", "cool-highlights", "look", "grade", "tint", "duotone", "fade"]
  },
  "params": {
    "shadow_hue":    { "type": "scalar", "range": [0, 360],    "default": 0, "unit": "deg" },
    "shadow_sat":    { "type": "scalar", "range": [0, 100],    "default": 0 },
    "highlight_hue": { "type": "scalar", "range": [0, 360],    "default": 0, "unit": "deg" },
    "highlight_sat": { "type": "scalar", "range": [0, 100],    "default": 0 },
    "balance":       { "type": "scalar", "range": [-100, 100], "default": 0 }
  },
  "bindings": [
    { "paramKey": "shadow_hue",    "controlType": "hue_wheel", "label": "Hue",        "group": "Shadows" },
    { "paramKey": "shadow_sat",    "controlType": "slider",    "label": "Saturation", "group": "Shadows" },
    { "paramKey": "highlight_hue", "controlType": "hue_wheel", "label": "Hue",        "group": "Highlights" },
    { "paramKey": "highlight_sat", "controlType": "slider",    "label": "Saturation", "group": "Highlights" },
    { "paramKey": "balance",       "controlType": "slider",    "label": "Balance",    "group": "Balance" }
  ],
  "engine": { "shader": "splitTone", "render_order": 30, "node_type": "splitTone" }
}
