{
  "id": "vignette",
  "display_name": "Vignette",
  "icon": "vignette",
  "category": "effect",
  "llm": {
    "description": "Edge darkening (negative amount) or lightening with controllable midpoint, feather, and roundness.",
    "typical_use": "Focus the eye on the subject, classical portrait darkening.",
    "semantic_tags": ["vignette", "edge", "framing", "darken-corners", "corners", "frame", "oval", "classical", "portrait", "focus"]
  },
  "params": {
    "amount":    { "type": "scalar", "range": [-100, 100], "default": 0 },
    "midpoint":  { "type": "scalar", "range": [0, 100],    "default": 50 },
    "feather":   { "type": "scalar", "range": [0, 100],    "default": 50 },
    "roundness": { "type": "scalar", "range": [-100, 100], "default": 0 }
  },
  "bindings": [
    { "paramKey": "amount",    "controlType": "slider", "label": "Amount" },
    { "paramKey": "midpoint",  "controlType": "slider", "label": "Midpoint" },
    { "paramKey": "feather",   "controlType": "slider", "label": "Feather" },
    { "paramKey": "roundness", "controlType": "slider", "label": "Roundness" }
  ],
  "engine": { "shader": "vignette", "render_order": 95, "node_type": "vignette" }
}
